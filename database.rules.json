{
  "rules": {
    ".read": false,
    ".write": false,
    "config": {
      "items12": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren() && newData.childrenCount() == 12",
        "$idx": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        }
      },
      "items6": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren() && newData.childrenCount() == 6",
        "$idx": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        }
      },
      "players": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren() && newData.childrenCount() <= 20",
        "$idx": {
          ".validate": "newData.hasChildren(['name', 'charName'])",
          "name": {
            ".validate": "newData.isString() && newData.val().length <= 30"
          },
          "lineId": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 80)"
          },
          "charName": {
            ".validate": "newData.isString() && newData.val().length <= 80"
          },
          "$other": {
            ".validate": false
          }
        }
      },
      "restrictMonths": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.childrenCount() <= 12",
        "$idx": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 12"
        }
      },
      "matchSchedule": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['matchesPerPair', 'weeks'])",
        "matchesPerPair": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
        },
        "weeks": {
          ".validate": "newData.hasChildren() && newData.childrenCount() <= 5",
          "$idx": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
          }
        },
        "$other": {
          ".validate": false
        }
      },
      "ocrDebug": {
        ".read": false,
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['ts']) && newData.childrenCount() <= 20",
        "$field": {
          ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean()"
        }
      },
      "uicolleNews": {
        ".read": false,
        ".write": false
      },
      "geoGame": {
        ".read": false,
        ".write": false
      },
      "aiChatGuard": {
        ".read": false,
        ".write": false
      },
      "$other": {
        ".read": false,
        ".write": false,
        ".validate": false
      }
    },
    "sessions": {
      ".read": "auth != null",
      "$sessionId": {
        ".write": "auth != null",
        "phase": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 3"
        },
        "spinning": {
          ".validate": "newData.isBoolean()"
        },
        "round1": {
          ".validate": "newData.childrenCount() <= 2",
          "$idx": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() < 12"
          }
        },
        "round2": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() < 6)"
        },
        "spinnerName": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "monthlyRules": {
      ".read": "auth != null",
      "$year": {
        "$month": {
          ".write": "auth != null",
          ".validate": "!newData.exists() || newData.hasChildren(['rule', 'decidedBy', 'decidedAt'])",
          "rule": {
            ".validate": "newData.isString() && newData.val().length <= 500"
          },
          "decidedBy": {
            ".validate": "newData.isString() && newData.val().length <= 40"
          },
          "decidedAt": {
            ".validate": "newData.isNumber()"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },
    "matchResults": {
      ".read": "auth != null",
      "$year": {
        "$month": {
          "$resultId": {
            ".write": "auth != null",
            ".validate": "!newData.exists() || newData.hasChildren(['date', 'away', 'home', 'awayScore', 'homeScore', 'addedBy', 'addedAt'])",
            "date": {
              ".validate": "newData.isString() && newData.val().length <= 20"
            },
            "away": {
              ".validate": "newData.isString() && newData.val().length <= 40"
            },
            "home": {
              ".validate": "newData.isString() && newData.val().length <= 40"
            },
            "awayScore": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
            },
            "homeScore": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
            },
            "awayPK": {
              ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 99)"
            },
            "homePK": {
              ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 99)"
            },
            "addedBy": {
              ".validate": "newData.isString() && newData.val().length <= 40"
            },
            "addedAt": {
              ".validate": "newData.isNumber()"
            },
            "$other": {
              ".validate": false
            }
          }
        }
      }
    },
    "deletionLog": {
      ".read": false,
      "monthlyRules": {
        "$key": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['deletedBy', 'deletedAt']) && newData.childrenCount() <= 2",
          "deletedBy": {
            ".validate": "newData.isString() && newData.val().length <= 40"
          },
          "deletedAt": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    },
    "spinHistory": {
      ".read": "auth != null",
      "$historyId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name', 'timestamp', 'round1', 'round2', 'savedAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "avatarUrl": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1000)"
        },
        "timestamp": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "round1": {
          ".validate": "newData.childrenCount() <= 2",
          "$idx": {
            ".validate": "newData.isString() && newData.val().length <= 80"
          }
        },
        "round2": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "savedAt": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "playerAvatars": {
      ".read": "auth != null",
      "$playerKey": {
        ".write": "auth != null",
        ".validate": "newData.isString() && newData.val().length <= 1000"
      }
    },
    "ocr_logs": {
      ".read": false,
      "$logId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['ts']) && newData.childrenCount() <= 20",
        "$field": {
          ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean()"
        }
      }
    },
    "diary": {
      ".read": false,
      ".write": false,
      ".indexOn": ["createdAt"]
    },
    "pendingOcr": {
      ".read": false,
      ".write": false
    },
    "geoGames": {
      ".read": false,
      ".write": false
    },
    "geoGameUsage": {
      ".read": false,
      ".write": false
    },
    "geoGameCache": {
      ".read": false,
      ".write": false
    },
    "aiChatUsage": {
      ".read": false,
      ".write": false
    },
    "conversations": {
      ".read": false,
      ".write": false,
      "$sourceId": {
        "messages": {
          ".indexOn": ["createdAt"]
        }
      }
    }
  }
}
