# LINE Messaging API
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Firebase (Service Account JSON を1行の文字列で貼り付け)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id",...}
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.asia-southeast1.firebasedatabase.app

# Public Firebase Web config for GitHub Pages app (Render側だけに置く)
FIREBASE_WEB_CONFIG_JSON={"apiKey":"...","authDomain":"your-project-id.firebaseapp.com","databaseURL":"https://...","projectId":"your-project-id","storageBucket":"...","messagingSenderId":"...","appId":"..."}

# Server
PORT=3000

# Optional AI chat (無料運用ならGemini無料枠 + Cloud Billing未設定を推奨)
AI_CHAT_ENABLED=false
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional OpenAI fallback (従量課金。無料運用なら設定しない)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

AI_COST_GUARD_ENABLED=true
AI_CHAT_DAILY_LIMIT=10
AI_CHAT_MONTHLY_LIMIT=50
AI_CHAT_DAILY_TOKEN_LIMIT=10000
AI_CHAT_MONTHLY_TOKEN_LIMIT=50000
AI_CHAT_ESTIMATED_TOKENS_PER_REPLY=900

# Optional private runtime seed. 実名・住所・通勤などをソースに置かずRender/Firebase側へ逃がす。
PRIVATE_PROFILE_SEEDS_JSON=[]
TRAPERUKO_OWNER_DISPLAY_NAME=
TRAPERUKO_ORIGIN_TEAM_NAME=
TOKUBAI_COORDINATE_AREA_FALLBACKS_JSON=[]
