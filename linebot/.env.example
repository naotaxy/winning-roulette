# LINE Messaging API
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Firebase (Service Account JSON を1行の文字列で貼り付け)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"winning-roulette-c6de7",...}
FIREBASE_DATABASE_URL=https://winning-roulette-c6de7-default-rtdb.asia-southeast1.firebasedatabase.app

# Server
PORT=3000

# Optional AI chat (課金リスクあり。無料運用なら設定しない / false のまま)
AI_CHAT_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
